# Copy this file to ".env" and fill in the values.

# OPENFDA_API_KEY
# Get this from the openFDA API portal:
# 1. Visit https://open.fda.gov/apis/authentication/
# 2. Follow the instructions to request an API key (free).
# 3. Paste the key value below.
OPENFDA_API_KEY=your_openfda_api_key_here

# ANTHROPIC_API_KEY
# Get this from your Anthropic console:
# 1. Sign in at https://console.anthropic.com/
# 2. Go to the API keys section and create a new key.
# 3. Paste the key value below.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

